import asyncio
from src.state import PlatformState
from src.core.embeddings import VectorEmbeddingRegistry
from src.agents.planner import RoutingAndPlannerAgent
from src.agents.validator import ValidatorAgent
from src.agents.executor import AsyncExecutorAgent

class SystemOrchestrationCoordinator:
   \"\"\"The Master Loop engine coordinating routing pipelines, multi-agent status tracking, and error handling.\"\"\"
   def __init__(self):
       self.vector_registry = VectorEmbeddingRegistry("registry/tool_metadata.json", "registry/embeddings.npy")
       self.planner = RoutingAndPlannerAgent()
       self.validator = ValidatorAgent()
       self.executor = AsyncExecutorAgent()

   async def run_workflow(self, state: PlatformState) -> PlatformState:
       # Step 1: Semantic Hybrid Filtering Retrieval
       state.top_k_tools = await self.vector_registry.get_top_k_tools(state.user_query, k=2)
       
       # Step 2: Plan Architecture Generation
       state.dag = await self.planner.run(state.user_query, state.top_k_tools)
       
       # Step 3: Core Pre-Execution Param Validation Check
       state.missing_fields = self.validator.validate(state.dag, state)
       if state.missing_fields:
           state.execution_status = "hitl_intervention"
           return state

       # Step 4: Asynchronous Parallel Execution DAG Processor Loop
       dag = state.dag
       while not all(node.status == "completed" for node in dag.execution_order):
           runnable_tasks = []
           for task in dag.execution_order:
               if task.status == "pending":
                   if all(dep in state.runtime_outputs for dep in task.depends_on):
                       runnable_tasks.append(task)
           
           if not runnable_tasks:
               state.execution_status = "failed"
               state.error_logs.append("Deadlock detected or unresolvable dependencies flagged inside workflow runtime.")
               return state

           for t in runnable_tasks: t.status = "running"
           
           # Fire concurrent asynchronous operational tasks in parallel
           tasks_pool = [self.executor.execute(task, state.runtime_outputs) for task in runnable_tasks]
           results = await asyncio.gather(*tasks_pool, return_exceptions=True)
           
           for task, res in zip(runnable_tasks, results):
               if isinstance(res, Exception):
                   task.status = "failed"
                   state.execution_status = "failed"
                   state.error_logs.append(f"Task {task.task_id} failed with: {str(res)}")
                   return state
               else:
                   task.status = "completed"
                   state.runtime_outputs[task.task_id] = res

       state.execution_status = "success"
       return state
"""

