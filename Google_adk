coordinator = SystemOrchestrationCoordinator()
session_datastore = {}

class ExecutionRequest(BaseModel):
   query: str

async def async_runner_task(session_id: str, query: str):
   state = PlatformState(session_id=session_id, user_query=query)
   session_datastore[session_id] = state
   await coordinator.run_workflow(state)

@app.get("/", response_class=HTMLResponse)
async def load_ui(request: Request):
   return templates.TemplateResponse("index.html", {"request": request})

@app.post("/api/v1/execute")
async def execute_query(payload: ExecutionRequest, background_tasks: BackgroundTasks):
   import uuid
   session_id = str(uuid.uuid4())
   background_tasks.add_task(async_runner_task, session_id, payload.query)
   return {"session_id": session_id, "status": "processing"}

@app.get("/api/v1/status/{session_id}")
async def get_status(session_id: str):
   state = session_datastore.get(session_id)
   if not state:
       raise HTTPException(status_code=404, detail="Requested sequence context not found")
   return {
       "status": state.execution_status,
       "outputs": state.runtime_outputs,
       "missing": state.missing_fields,
       "errors": state.error_logs
   }

